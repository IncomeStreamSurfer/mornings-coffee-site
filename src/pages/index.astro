---
import Layout from '../layouts/Layout.astro';

const LAUNCH_DATE_ISO = '2026-06-17T13:00:00Z';
const launchDate = new Date(LAUNCH_DATE_ISO);
const launchDateLabel = launchDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<Layout
  title="Mornings — small-batch coffee, soon"
  description="Mornings is a new small-batch coffee brand built for the quiet half of the day. Join the waitlist to be first in line when we launch."
>
  <main class="relative min-h-screen w-full overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 -z-0"
      style="background: radial-gradient(1000px 600px at 20% 10%, #fdf9f1 0%, #faf3e7 40%, #f3e6cf 100%);"
    >
    </div>

    <div class="relative z-10 mx-auto flex min-h-screen max-w-6xl flex-col px-6 py-8 md:px-10">
      <header class="flex items-center justify-between">
        <a href="/" class="flex items-center gap-3" aria-label="Mornings home">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-brown-800 text-cream-100" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path class="steam" d="M8 3c0 1-1 1.5-1 3s1 2 1 3" opacity="0.6"></path>
              <path class="steam" d="M12 3c0 1-1 1.5-1 3s1 2 1 3" opacity="0.6"></path>
              <path class="steam" d="M16 3c0 1-1 1.5-1 3s1 2 1 3" opacity="0.6"></path>
              <path d="M3 11h14v3a5 5 0 0 1-5 5H8a5 5 0 0 1-5-5v-3z"></path>
              <path d="M17 12h1.5a2.5 2.5 0 0 1 0 5H17"></path>
            </svg>
          </span>
          <span class="font-display text-xl font-bold tracking-tight text-brown-800">Mornings</span>
        </a>
        <span class="hidden text-xs uppercase tracking-[0.3em] text-brown-500 md:inline">Coming soon</span>
      </header>

      <section class="flex flex-1 flex-col items-start justify-center py-16 md:py-24">
        <p class="mb-5 text-xs uppercase tracking-[0.35em] text-brown-500">
          Est. <span class="text-brown-700">2026</span> &middot; Single origin, slow roast
        </p>

        <h1 class="font-display text-5xl font-bold leading-[1.02] tracking-tight text-brown-900 md:text-7xl lg:text-[88px]">
          Coffee for the <br />
          <em class="italic text-brown-700">quiet half</em> of the day.
        </h1>

        <p class="mt-7 max-w-xl text-lg leading-relaxed text-brown-700 md:text-xl">
          Mornings is a small-batch roaster obsessed with what happens before the rest of
          the world wakes up. We're almost ready to pour &mdash; join the waitlist and we'll
          email you the moment the first bag ships.
        </p>

        <div
          id="countdown"
          class="mt-10 grid grid-cols-4 gap-3 md:gap-5"
          data-launch={LAUNCH_DATE_ISO}
          aria-label={`Countdown to launch on ${launchDateLabel}`}
        >
          {
            [
              { key: 'days', label: 'Days' },
              { key: 'hours', label: 'Hours' },
              { key: 'minutes', label: 'Minutes' },
              { key: 'seconds', label: 'Seconds' },
            ].map((unit) => (
              <div class="flex min-w-[72px] flex-col items-center rounded-xl border border-cream-300 bg-cream-50/80 px-4 py-3 text-brown-900 shadow-[0_1px_0_rgba(62,42,31,0.05)] backdrop-blur md:min-w-[96px] md:px-5 md:py-4">
                <span data-unit={unit.key} class="font-display text-3xl font-bold tabular-nums md:text-5xl">
                  --
                </span>
                <span class="mt-1 text-[10px] uppercase tracking-[0.25em] text-brown-500 md:text-xs">
                  {unit.label}
                </span>
              </div>
            ))
          }
        </div>
        <p class="mt-3 text-sm text-brown-500">Launching {launchDateLabel}</p>

        <form id="waitlist-form" class="mt-10 flex w-full max-w-xl flex-col gap-3 sm:flex-row" novalidate>
          <label for="email" class="sr-only">Email address</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="you@yourmornings.com"
            class="flex-1 rounded-lg border border-cream-300 bg-white/80 px-4 py-3 text-base text-brown-900 placeholder:text-brown-500/70 focus:border-brown-700 focus:outline-none focus:ring-2 focus:ring-brown-700/20"
          />
          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-lg bg-brown-800 px-5 py-3 text-base font-medium text-cream-100 transition hover:bg-brown-700 focus:outline-none focus:ring-2 focus:ring-brown-700/30 disabled:opacity-60"
          >
            <span data-label>Join the waitlist</span>
          </button>
        </form>
        <p id="form-msg" class="mt-3 min-h-[1.25rem] text-sm text-brown-600" aria-live="polite">
          We'll only email you once &mdash; when the beans are ready.
        </p>
      </section>

      <footer class="mt-auto flex flex-col items-start justify-between gap-4 pt-8 text-sm text-brown-500 md:flex-row md:items-center">
        <div class="flex items-center gap-2">
          <span class="inline-block h-2 w-2 rounded-full bg-brown-700" aria-hidden="true"></span>
          <span>Roasted in small batches. Shipped slowly. Brewed carefully.</span>
        </div>
        <div class="flex items-center gap-4">
          <span>&copy; {new Date().getFullYear()} Mornings Coffee Co.</span>
        </div>
      </footer>
    </div>
  </main>

  <script is:inline>
    (function () {
      const root = document.getElementById('countdown');
      if (!root) return;
      const launch = new Date(root.dataset.launch || '').getTime();
      const $ = (k) => root.querySelector(`[data-unit="${k}"]`);

      function tick() {
        const now = Date.now();
        let diff = Math.max(0, launch - now);
        const d = Math.floor(diff / 86400000);
        diff -= d * 86400000;
        const h = Math.floor(diff / 3600000);
        diff -= h * 3600000;
        const m = Math.floor(diff / 60000);
        diff -= m * 60000;
        const s = Math.floor(diff / 1000);
        const pad = (n, len = 2) => String(n).padStart(len, '0');
        const set = (key, val) => { const el = $(key); if (el) el.textContent = val; };
        set('days', pad(d, d > 99 ? 3 : 2));
        set('hours', pad(h));
        set('minutes', pad(m));
        set('seconds', pad(s));
      }
      tick();
      setInterval(tick, 1000);
    })();

    (function () {
      const form = document.getElementById('waitlist-form');
      if (!form) return;
      const msg = document.getElementById('form-msg');
      const btn = form.querySelector('button[type="submit"]');
      const btnLabel = btn ? btn.querySelector('[data-label]') : null;
      const emailInput = form.querySelector('#email');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!emailInput || !msg || !btn) return;
        const email = String(emailInput.value || '').trim();
        if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
          msg.textContent = 'Please enter a valid email address.';
          msg.style.color = '#6e4530';
          return;
        }

        btn.disabled = true;
        if (btnLabel) btnLabel.textContent = 'Saving...';
        msg.textContent = '';

        try {
          const res = await fetch('/api/waitlist', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, referrer: document.referrer || null }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            msg.textContent = data && data.error ? data.error : 'Something went wrong. Please try again.';
            msg.style.color = '#6e4530';
            btn.disabled = false;
            if (btnLabel) btnLabel.textContent = 'Join the waitlist';
            return;
          }
          msg.textContent = "You're on the list. Check your inbox for a hello from us.";
          msg.style.color = '#3e2a1f';
          emailInput.value = '';
          if (btnLabel) btnLabel.textContent = 'Added ✓';
        } catch (err) {
          msg.textContent = 'Network error. Please try again.';
          msg.style.color = '#6e4530';
          btn.disabled = false;
          if (btnLabel) btnLabel.textContent = 'Join the waitlist';
        }
      });
    })();
  </script>
</Layout>
